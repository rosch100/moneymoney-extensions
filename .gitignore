# Lua-Build-Tooling (lokal, nicht ins Repo)
/luarocks
/lua
/lua_modules/
/.luarocks/
/.vscode/
!/moneymoney-dev-1.rockspec

# Sensitive Daten / HAR-Exporte
*.har
*_cookies.txt

# Python-Caches
**/__pycache__/
*.pyc

# Lokale Reverse-Engineering-Referenz (nicht veröffentlichen)
/docs/UNDOCUMENTED-MM-LUA-API.md

# Xcode: benutzerspezifische UI/Workspace-States
safari-extension/**/xcuserdata/

# Nur Dateien aus extensions/, scripts/, docs/ und tests/ ins Repo,
# Lua-Dateien im Root ausschließen (Entwicklungs-Scratch).
/*.lua
!/extensions/*.lua
!/tests/*.lua
